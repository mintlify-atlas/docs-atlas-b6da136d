  "publicApiSurface": [
    "POST /add - Add memory to vector store",
    "GET /search - Search memories by query",
    "GET /get_all - Retrieve all memories for user",
    "PUT /update - Update existing memory",
    "DELETE /delete - Delete memory by ID",
    "POST /api/chat - Stream chat completions",
    "POST /api/completion - Generate AI completions",
    "POST /api/interview-copilot - Analyze coding problems",
    "POST /api/suggest - Get inline suggestions",
    "POST /api/voice-agent - Voice agent interactions",
    "POST /api/transcribe - Transcribe audio to text",
